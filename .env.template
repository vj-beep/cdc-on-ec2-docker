# ============================================================
# cdc-poc-confluent-platform — Environment Configuration
# ============================================================
# 1. Copy this file:  cp .env.template .env
# 2. Fill in the blank values below from your AWS environment
# 3. Copy the completed .env to all 5 EC2 nodes
# ============================================================
#
# ⚠️  SECURITY WARNING ⚠️
# This file contains database credentials, passwords, and keys.
# NEVER commit this file to version control or share publicly.
# .env is git-ignored by default — do NOT change this.
# Treat .env with the same security as AWS credentials and API keys.
# Use a secrets manager (HashiCorp Vault, AWS Secrets Manager, 1Password)
# to distribute credentials securely in production deployments.
# ============================================================

# ============================================================
# DEPLOYMENT CORE
# ============================================================
# Bootstrap variables required before infrastructure discovery.

# --- Public Repository URL ---
# Used by 2a-deploy-repo.sh to clone the repo to all EC2 nodes.
# Set this to your GitHub (or other Git hosting) URL for the public repo.
# Example: https://github.com/your-org/cdc-on-ec2-docker.git
PUBLIC_REPO_URL=                # REQUIRED: Git URL used by 2a-deploy-repo.sh to clone to EC2 nodes

# --- Deployment User & Directory ---
DEPLOY_USER=ec2-user
DEPLOY_DIR=/home/${DEPLOY_USER}/cdc-on-ec2-docker

# --- Storage Configuration ---
# Kafka data directory (mount point for broker log storage).
# Default: /data/kafka (assumes NVMe or high-performance storage mounted here)
# For on-prem or different cloud: adjust to your storage path (e.g., /var/kafka, /mnt/storage)
# Directory will be created if it doesn't exist (requires docker-compose to run as root or with appropriate permissions).
KAFKA_DATA_DIR=/data/kafka

# --- HTTP Proxy ---
# Most enterprise environments route EC2 traffic through a corporate proxy.
# Set these to your proxy URL. Used by:
#   - Docker daemon (image pulls)           → 3-setup-ec2.sh configures systemd drop-in
#   - Docker build (curl/Maven downloads)   → build args in docker-compose.connect-build.yml
#   - Docker build (confluent-hub install)  → JAVA_TOOL_OPTIONS in Dockerfile
#   - Container runtime (license checks)    → env vars in docker-compose.yml
#
# TO DISABLE PROXY (direct internet access): leave all five vars empty.
# When empty, no proxy is configured at any layer.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,169.254.169.254
# Java proxy host and port (confluent-hub install ignores HTTP_PROXY/HTTPS_PROXY).
# Example: PROXY_HOST=proxy.corp.example.com  PROXY_PORT=3128
PROXY_HOST=
PROXY_PORT=8080

# --- KRaft Cluster ID ---
# Generate once (URL-safe Base64, 22 chars — matches kafka-storage format):
#   python3 -c "import uuid,base64; print(base64.urlsafe_b64encode(uuid.uuid4().bytes).decode().rstrip('='))"
CLUSTER_ID=


# ============================================================
# INFRASTRUCTURE
# ============================================================
# EC2 node discovery and dispatch configuration.

# --- EC2 Node Private IPs ---
# Find in: AWS Console > EC2 > Instances > Private IPv4 address
# Each node must be reachable from the others on the ports listed in README.
# See README.md for infrastructure requirements (vCPU, RAM, storage per role).
BROKER_1_IP=                # Node 1: Broker 1 (KRaft Controller)
BROKER_2_IP=                # Node 2: Broker 2 (KRaft Controller)
BROKER_3_IP=                # Node 3: Broker 3 (KRaft Controller)
CONNECT_1_IP=               # Node 4: Connect Workers + Schema Registry
MONITOR_1_IP=               # Node 5: Control Center + ksqlDB + Monitoring

# --- EC2 Instance IDs (required for SSM dispatch mode only) ---
# Find in: AWS Console > EC2 > Instances > Instance ID
# Not required when DISPATCH_MODE=ssh — scripts use *_IP vars instead.
BROKER_1_INSTANCE_ID=       # EC2 Instance ID for Broker 1 (e.g., i-0abc123...)
BROKER_2_INSTANCE_ID=       # EC2 Instance ID for Broker 2
BROKER_3_INSTANCE_ID=       # EC2 Instance ID for Broker 3
CONNECT_1_INSTANCE_ID=      # EC2 Instance ID for Connect node (Node 4)
MONITOR_1_INSTANCE_ID=      # EC2 Instance ID for Monitor node (Node 5)

# --- Dispatch Mode ---
# Controls how multi-node scripts reach EC2 nodes.
#
#   ssm  (default) — AWS Systems Manager Session Manager. No SSH keys needed.
#                    Requires: IAM instance profile with AmazonSSMManagedInstanceCore,
#                    SSM VPC endpoints (PrivateLink) if nodes have no internet egress.
#                    Uses: *_INSTANCE_ID vars above.
#
#   ssh             — Direct SSH. Requires SSH key distributed to all nodes.
#                    Requires: SSH_KEY_PATH set below, key authorised on all nodes.
#                    Uses: *_IP vars. INSTANCE_IDs not required.
#
# Both modes require proxy (HTTP_PROXY/HTTPS_PROXY) — no direct internet egress assumed.
DISPATCH_MODE=ssm

# Path to SSH private key. Used only when DISPATCH_MODE=ssh.
# Example: SSH_KEY_PATH=~/.ssh/id_rsa
SSH_KEY_PATH=

# --- AWS Region ---
# Used by SSM scripts (default: us-east-1) and Grafana CloudWatch datasource.
# Set to empty string ("") or "local" for on-prem deployments.
AWS_REGION=us-east-1

# ============================================================
# DATABASE CONNECTIVITY
# ============================================================
# All database credentials and endpoints. Must be reachable from EC2 nodes.

# --- SQL Server RDS ---
# Find host in: AWS Console > RDS > Instances > Endpoint (RDS)
#               or EC2 private IP if SQL Server is self-hosted on EC2
SQLSERVER_HOST=             # e.g., my-sqlserver.xxxx.us-east-1.rds.amazonaws.com
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=         # REQUIRED: Your SQL Server database name
SQLSERVER_USER=cdcadmin
SQLSERVER_PASSWORD=         # The password you configured for the SQL Server admin user

# --- Aurora PostgreSQL RDS ---
# Find host in: AWS Console > RDS > Clusters > Writer instance endpoint
# Password is what you set when creating the Aurora cluster.
AURORA_HOST=                # e.g., my-cluster.cluster-xxxx.us-east-1.rds.amazonaws.com
AURORA_PORT=5432
AURORA_DATABASE=            # REQUIRED: Your Aurora database name
AURORA_USER=cdcadmin
AURORA_PASSWORD=            # The password you configured for the Aurora admin user

# ============================================================
# CDC FORWARD PATH: SQL Server → Aurora PostgreSQL
# ============================================================
# Define SQL Server as source, Aurora as sink.
# These variables must be set together and aligned.

# --- SQL Server Source Configuration ---
# Which tables to capture from SQL Server CDC (via Debezium)
# POC: Only workitemdata has CDC enabled on SQL Server source, so explicitly specify it.
#
# INCLUDE_LIST (recommended):
#   - Set to specific tables = only replicate listed CDC-enabled tables (safer, explicit intent)
#   - Example: dbo.workitemdata  (single table)
#   - Example: dbo.workitemdata,dbo.customers,dbo.orders  (multiple tables)
#   - Leave EXCLUDE_LIST blank when INCLUDE_LIST is set
#
# EXCLUDE_LIST (not recommended for CDC):
#   - Blank = capture all CDC-enabled tables
#   - Only use EXCLUDE_LIST if you want to explicitly disable specific CDC-enabled tables
#   - When both INCLUDE and EXCLUDE are set, INCLUDE takes precedence
SQLSERVER_TABLE_INCLUDE_LIST=dbo.workitemdata       # Explicitly specify CDC-enabled tables to replicate
SQLSERVER_TABLE_EXCLUDE_LIST=dbo._none             # Placeholder (not used when INCLUDE_LIST is set)

# Message key columns for tables without a primary key
# Format: fully-qualified-table:col1,col2;another-table:col1,col2
# POC defaults: events_log (SQL Server) and inventory_log (Aurora) have no PKs.
# generate-env.sh auto-populates these with the correct database name.
# If not using generate-env.sh, replace 'pocdb' with your SQLSERVER_DATABASE value.
SQLSERVER_MESSAGE_KEY_COLUMNS=pocdb.dbo.events_log:event_timestamp,entity_type,entity_id

# SQL Server CDC agent (internal database configuration)
CDC_CAPTURE_MAXTRANS=10000
CDC_CAPTURE_MAXSCANS=100
CDC_CAPTURE_POLLING=0

# Debezium SQL Server source connector tuning
SQLSERVER_TOPIC_PREFIX=sqlserver
SQLSERVER_SCHEMA_HISTORY_TOPIC=_schema-history-sqlserver
SQLSERVER_SOURCE_SNAPSHOT_MODE=initial
SQLSERVER_SOURCE_SNAPSHOT_FETCH_SIZE=10240
SQLSERVER_SOURCE_MAX_BATCH_SIZE=4096
SQLSERVER_SOURCE_MAX_QUEUE_SIZE=32768
SQLSERVER_SOURCE_MAX_QUEUE_SIZE_IN_BYTES=134217728
SQLSERVER_SOURCE_POLL_INTERVAL_MS=100

# --- Aurora Sink (JDBC) Configuration ---
# TOPICS_REGEX vs TOPIC_REGEX — two different variables, two different escaping rules:
#
#   JDBC_SINK_AURORA_TOPICS_REGEX  → connector "topics.regex" property
#     • Used by Kafka Connect to select which topics this sink subscribes to
#     • Stored in .env with double-escaped dots (\\.): the Python substitution in
#       6-deploy-connectors.sh writes it into JSON where \\ becomes a single \,
#       so the deployed connector sees sqlserver\..*\.dbo\.(workitemdata)
#     • Pattern: sqlserver\\..*\\.dbo\\.(tablename)
#
#   JDBC_SINK_AURORA_TOPIC_REGEX   → RegexRouter SMT "regex" property
#     • Used by the RegexRouter SMT to extract the table name from the topic,
#       so the sink writes to the correct destination table
#     • Stored in .env with single-escaped dots (\.): envsubst/python writes it
#       directly into JSON as-is, producing sqlserver\.[^.]+\.dbo\.(tablename)
#     • Must contain a capture group (...) — $1 in the SMT "replacement" extracts
#       just the table name: sqlserver.pocdb.dbo.workitemdata → workitemdata
#     • Pattern: sqlserver\.[^.]+\.dbo\.(tablename)
#
# POC: Only workitemdata is CDC-enabled on SQL Server source
# For multiple tables, use: sqlserver\\..*\\.dbo\\.(workitemdata|customers|orders)
JDBC_SINK_AURORA_TOPICS_REGEX='sqlserver\..*\.dbo\.(workitemdata)'

# For multiple tables: sqlserver\.[^.]+\.dbo\.(workitemdata|customers|orders)
JDBC_SINK_AURORA_TOPIC_REGEX='sqlserver\.[^.]+\.dbo\.(workitemdata)'

# JDBC sink connector tuning
# PRIMARY KEY MODE: record_key (recommended)
# The Debezium source connector automatically extracts the table's primary key columns
# and uses them as the Kafka record key. The sink uses these record keys for upserts.
# This approach handles:
#   - Single primary keys: workitemid (extracted to record key automatically)
#   - Composite primary keys: (customer_id, order_id) (combined in record key)
#   - Multiple tables with different PKs in ONE sink (each table's PK in its record key)
# No need to manually specify PK column names — the source connector does it automatically.
JDBC_SINK_AURORA_BATCH_SIZE=5000
JDBC_SINK_AURORA_TASKS_MAX=4

# NOTE: Must also set CONNECT_CONSUMER_* and CONNECT_PRODUCER_* tuning in PLATFORM TUNING section below

# ============================================================
# CDC REVERSE PATH: Aurora PostgreSQL → SQL Server
# ============================================================
# Define Aurora as source, SQL Server as sink.
# These variables must be set together and aligned.

# --- Aurora Source Configuration ---
# Which tables to capture from Aurora CDC (via logical replication publication)
# POC: Only products is in the publication on Aurora source, so explicitly specify it.
#
# INCLUDE_LIST (recommended):
#   - Set to specific tables = only replicate listed publication members (safer, explicit intent)
#   - Example: public.products  (single table)
#   - Example: public.products,public.customers,public.price_history  (multiple tables)
#   - Leave EXCLUDE_LIST blank when INCLUDE_LIST is set
#
# EXCLUDE_LIST (not recommended for CDC):
#   - Blank = capture all publication members
#   - Only use EXCLUDE_LIST if you want to explicitly disable specific publication members
#   - When both INCLUDE and EXCLUDE are set, INCLUDE takes precedence
AURORA_TABLE_INCLUDE_LIST=public.products           # Explicitly specify publication members to replicate
AURORA_TABLE_EXCLUDE_LIST=public._none              # Placeholder (not used when INCLUDE_LIST is set)

# Message key columns for tables without a primary key
# Format: fully-qualified-table:col1,col2;another-table:col1,col2
AURORA_MESSAGE_KEY_COLUMNS=public.inventory_log:log_timestamp,product_id,warehouse_id

# PostgreSQL replication setup
PG_SLOT_NAME=debezium_cdc
PG_PUBLICATION_NAME=cdc_publication
AURORA_SCHEMA_INCLUDE_LIST=public

# Debezium Aurora source connector tuning
AURORA_TOPIC_PREFIX=aurora
AURORA_SCHEMA_HISTORY_TOPIC=_schema-history-aurora
AURORA_SOURCE_SNAPSHOT_MODE=initial
AURORA_SOURCE_SNAPSHOT_FETCH_SIZE=10240
AURORA_SOURCE_MAX_BATCH_SIZE=4096
AURORA_SOURCE_MAX_QUEUE_SIZE=32768
AURORA_SOURCE_MAX_QUEUE_SIZE_IN_BYTES=134217728
AURORA_SOURCE_POLL_INTERVAL_MS=100

# --- SQL Server Sink (JDBC) Configuration ---
# TOPICS_REGEX vs TOPIC_REGEX — same escaping rules as Aurora sink above:
#
#   JDBC_SINK_SQLSERVER_TOPICS_REGEX  → connector "topics.regex" (double-escaped \\.  for JSON)
#   JDBC_SINK_SQLSERVER_TOPIC_REGEX   → RegexRouter SMT "regex"   (single-escaped \.  for JSON)
#
# POC: Only products is CDC-enabled on Aurora source
# For multiple tables, use: aurora\\.public\\.(products|customers|price_history)
JDBC_SINK_SQLSERVER_TOPICS_REGEX='aurora\\.public\\.(products)'

# For multiple tables: aurora\.public\.(products|customers|price_history)
JDBC_SINK_SQLSERVER_TOPIC_REGEX='aurora\.public\.(products)'

# JDBC sink connector tuning
# PRIMARY KEY MODE: record_key (recommended)
# The Debezium source connector automatically extracts the table's primary key columns
# and uses them as the Kafka record key. The sink uses these record keys for upserts.
# This approach handles:
#   - Single primary keys: product_id (extracted to record key automatically)
#   - Composite primary keys: (warehouse_id, sku) (combined in record key)
#   - Multiple tables with different PKs in ONE sink (each table's PK in its record key)
# No need to manually specify PK column names — the source connector does it automatically.
JDBC_SINK_SQLSERVER_BATCH_SIZE=5000
JDBC_SINK_SQLSERVER_TASKS_MAX=1

# NOTE: Must also set CONNECT_CONSUMER_* and CONNECT_PRODUCER_* tuning in PLATFORM TUNING section below

# ============================================================
# PLATFORM TUNING — Kafka, Connect, Debezium
# ============================================================
# Applies to both forward and reverse CDC paths.
# Predefined profiles: SNAPSHOT (initial bulk transfer) and STREAMING (steady-state CDC).
# Start with defaults (SNAPSHOT), adjust after monitoring the initial snapshot.
# Switch profiles: ./scripts/on-demand-switch-profile.sh streaming

# --- Confluent Platform Versions ---
CP_VERSION=8.0.0
CONTROL_CENTER_VERSION=2.2.0

# --- Kafka Broker Core ---
KAFKA_REPLICATION_FACTOR=3
KAFKA_MIN_INSYNC_REPLICAS=2
KAFKA_LOG_RETENTION_HOURS=72
KAFKA_LOG_RETENTION_BYTES=5368709120
KAFKA_LOG_SEGMENT_BYTES=536870912
KAFKA_AUTO_CREATE_TOPICS=true
KAFKA_DEFAULT_PARTITIONS=3
KAFKA_TOPIC_RETENTION_MS=259200000

# --- Kafka Broker IO & Network Tuning ---
KAFKA_REPLICA_FETCH_MAX_BYTES=10485760
KAFKA_MESSAGE_MAX_BYTES=10485760
KAFKA_SOCKET_SEND_BUFFER_BYTES=1048576
KAFKA_SOCKET_RECEIVE_BUFFER_BYTES=1048576
KAFKA_NUM_IO_THREADS=16
KAFKA_NUM_NETWORK_THREADS=8
KAFKA_LOG_FLUSH_INTERVAL_MESSAGES=50000

# --- Connect Workers ---
# Two separate Connect clusters (group IDs hardcoded in docker-compose.yml):
#   connect-forward (port 8083): SQL Server -> Kafka -> Aurora
#   connect-reverse (port 8084): Aurora -> Kafka -> SQL Server
CONNECT_OFFSET_FLUSH_INTERVAL_MS=60000

# --- Connect Consumer Tuning (reads from Kafka) ---
# Applied to both SQLSERVER_SOURCE and AURORA_SOURCE connectors
CONNECT_CONSUMER_FETCH_MAX_BYTES=104857600
CONNECT_CONSUMER_FETCH_MIN_BYTES=1048576
CONNECT_CONSUMER_FETCH_MAX_WAIT_MS=500
CONNECT_CONSUMER_MAX_POLL_RECORDS=5000
CONNECT_CONSUMER_MAX_PARTITION_FETCH_BYTES=10485760
CONNECT_CONSUMER_SESSION_TIMEOUT_MS=60000
CONNECT_CONSUMER_HEARTBEAT_INTERVAL_MS=20000

# --- Connect Producer Tuning (writes to Kafka) ---
# Applied to source connectors (emit CDC to Kafka)
CONNECT_PRODUCER_BATCH_SIZE=524288
CONNECT_PRODUCER_LINGER_MS=100
CONNECT_PRODUCER_BUFFER_MEMORY=134217728
CONNECT_PRODUCER_COMPRESSION_TYPE=snappy
CONNECT_PRODUCER_MAX_REQUEST_SIZE=10485760

# ============================================================
# MONITORING & INFRASTRUCTURE SERVICES
# ============================================================

# --- Service Ports ---
SCHEMA_REGISTRY_PORT=8081
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
KSQLDB_PORT=8088
JMX_EXPORTER_PORT=9404
FLINK_JOBMANAGER_PORT=8081

# --- Monitoring Stack ---
GRAFANA_ADMIN_PASSWORD=admin          # REQUIRED: Change before deployment — never leave as default
PROMETHEUS_VERSION=v3.4.1
GRAFANA_VERSION=11.6.0
ALERTMANAGER_VERSION=v0.28.1
NODE_EXPORTER_VERSION=v1.9.1
CADVISOR_VERSION=v0.52.1

# --- Apache Flink ---
FLINK_VERSION=1.19-java11

