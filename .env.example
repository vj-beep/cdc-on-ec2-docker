# ============================================================
# Example: POC deployment with 3 test tables
# ============================================================
# This shows EXAMPLE customer-specific CDC variables.
# CUSTOMIZE: Replace database names, table names, and topic
# patterns below to match your environment before copying
# values into your .env file.
#
# Tables replicated (examples):
#   SQL Server: dbo.customers (PK+PII), dbo.orders (PK), dbo.events_log (no PK)
#   Aurora PG:  public.customers, public.orders, public.events_log
# ============================================================

# --- Databases (CUSTOMIZE: replace with your database names) ---
SQLSERVER_DATABASE=pocdb
AURORA_DATABASE=pocdb

# --- CDC Reader User (used by sink connectors only) ---
# Source (Debezium) connectors use admin credentials (SQLSERVER_USER / AURORA_USER)
# because RDS does not allow granting CDC/REPLICATION to non-admin roles.
CDC_READER_USER=cdc_reader
CDC_READER_PASSWORD=          # Set to the password you created for the cdc_reader user

# --- SQL Server Source Connector (CUSTOMIZE: your tables) ---
SQLSERVER_TOPIC_PREFIX=sqlserver
SQLSERVER_TABLE_INCLUDE_LIST=dbo.customers,dbo.orders,dbo.events_log
SQLSERVER_SCHEMA_HISTORY_TOPIC=_schema-history-sqlserver

# --- Aurora PostgreSQL Source Connector (CUSTOMIZE: your tables) ---
AURORA_TOPIC_PREFIX=aurora
AURORA_SCHEMA_INCLUDE_LIST=public
AURORA_TABLE_INCLUDE_LIST=public.customers,public.orders,public.events_log
AURORA_SCHEMA_HISTORY_TOPIC=_schema-history-aurora
PG_SLOT_NAME=debezium_cdc
PG_PUBLICATION_NAME=cdc_publication

# --- JDBC Sink: SQL Server -> Aurora (CUSTOMIZE: match your db/table names) ---
# Debezium SQL Server topic format: {prefix}.{database}.{schema}.{table}
JDBC_SINK_AURORA_TOPICS=sqlserver.pocdb.dbo.customers,sqlserver.pocdb.dbo.orders,sqlserver.pocdb.dbo.events_log
JDBC_SINK_AURORA_TOPIC_REGEX=sqlserver\\.pocdb\\.dbo\\.(.*)

# --- JDBC Sink: Aurora -> SQL Server (CUSTOMIZE: match your schema/table names) ---
# Debezium PostgreSQL topic format: {prefix}.{schema}.{table}
JDBC_SINK_SQLSERVER_TOPICS=aurora.public.customers,aurora.public.orders,aurora.public.events_log
JDBC_SINK_SQLSERVER_TOPIC_REGEX=aurora\\.public\\.(.*)
